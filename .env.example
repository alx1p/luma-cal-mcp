# Optional — authenticated session cookie for subscribed calendars
# Exact format determined by inspecting luma.com network requests while logged in.
# Without this, Discover still works but subscribed calendars return empty.
# NEVER commit this value.
LUMA_WEB_SESSION=

# Optional defaults — override via tool parameters at call time
DEFAULT_CITY=
DEFAULT_CATEGORY=
DEFAULT_CENTER_LAT=
DEFAULT_CENTER_LON=
DEFAULT_CENTER_ADDRESS=
DEFAULT_MAX_DISTANCE_MILES=
DEFAULT_KEYWORDS=

# Geocoding provider: nominatim (default, free), google, or mapbox
GEOCODING_PROVIDER=nominatim
GEOCODING_API_KEY=

# Path to SQLite DB for tracking when events were first seen.
# Default: ~/.luma-mcp/events.db
EVENT_STORE_PATH=
